{
  "name": "copy-as-real-file",
  "publisher": "Lilia",
  "displayName": "copy-as-real-file",
  "description": "Copy VSCode/VSCodium files to clipboard as CF_HDROP or URL with MIME",
  "version": "0.0.5",
  "icon": "icon.PNG",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.copyAsFile",
        "title": "复制为真实文件 (Copy as File)",
        "icon": "$(file-symlink-file)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceScheme == file",
          "command": "extension.copyAsFile",
          "group": "4_modification"
        }
      ],
      "keybindings": [
        {
          "command": "extension.copyAsFile",
          "key": "ctrl+alt+c",
          "mac": "cmd+alt+c",
          "when": "filesExplorerFocus || editorTextFocus"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
